--2. Student Table
--
--Create a table to store information about students.
--
--Column	Data Type	Description
--Student ID	NUMBER	Unique ID of student
--Student Name	VARCHAR2(100)	Full name
--Email	VARCHAR2(100)	Student email
--Gender	VARCHAR2(10)	Male/Female
--Date of Birth	DATE	Student birth date
--Phone Number	VARCHAR2(20)	Student phone
--Department ID	NUMBER	Department of student
--Admission Year	NUMBER(4)	Year student was admitted

CREATE TABLE Students (
    Student_ID NUMBER PRIMARY KEY,
    Student_Name VARCHAR2(100) NOT NULL,
    Email VARCHAR2(100) UNIQUE,
    Gender VARCHAR2(10),
    Date_of_Birth DATE,
    Phone_Number VARCHAR2(20),
    Department_ID NUMBER,
    Admission_Year NUMBER(4),

    CONSTRAINT fk_student_department FOREIGN KEY (Department_ID) REFERENCES Department(Department_ID)
);
-- DELETING TABLE
DROP TABLE STUDENTS;
