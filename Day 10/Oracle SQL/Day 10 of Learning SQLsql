--3. Course Table
--Column	Data Type	Description
--Course ID	NUMBER	Unique course ID
--Course Name	VARCHAR2(100)	Name of course
--Credit Hours	NUMBER(2)	Course credit hours
--Semester	NUMBER(2)	Semester in which course is offered
--Department ID	NUMBER	Department offering the course

CREATE TABLE COURSE(
COURSE_ID Number PRIMARY KEY,
COURSE_NAME VARCHAR2(100),
CREDIT_HOURS NUMBER(2),
SEMESTER NUMBER(2) ,
DEPT_ID NUMBER,
CONSTRAINT COURSE_DEPT FOREIGN KEY(DEPT_ID) REFERENCES DEPARTMENT(DEPARTMENT_ID)
);

