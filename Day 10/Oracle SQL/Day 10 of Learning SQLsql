--1. Department Table
--
--Create a table to store information about university departments.
--
--Column	Data Type	Description
--Department ID	NUMBER	Unique ID of department
--Department Name	VARCHAR2(100)	Name of department
--HOD Name	VARCHAR2(100)	Name of Head of Department
--Building	VARCHAR2(50)	Department building
--Contact Number	VARCHAR2(20)	Department contact

--Rule: Phone numbers → VARCHAR2 ✅
--Numbers used for calculations → NUMBER ✅

CREATE TABLE DEPARTMENT(
DEPARTMENT_ID NUMBER PRIMARY KEY,
DEPARTMENT_NAME VARCHAR2(100),
HOD_NAME VARCHAR2(100),
BUILDING VARCHAR2(50),
CONTACT_NUMBER VARCHAR2(20));

